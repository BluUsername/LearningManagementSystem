# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real secrets.

# --- Django Settings ---
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (leave blank for SQLite in development)
DATABASE_URL=

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Set to 'production' to enforce SECRET_KEY requirement
DJANGO_ENV=development

# --- Postgres (used by docker-compose db + backend services) ---
POSTGRES_DB=lms_db
POSTGRES_USER=lms_user
# Must be URL-safe: avoid @ : / # % and other reserved URI characters because
# docker-compose embeds this value directly into the DATABASE_URL connection string.
# Use hex-only generators (e.g. openssl rand -hex 32) to stay safe.
# If your password contains a literal $, escape it as $$ in this file so that
# docker-compose does not treat it as a variable reference.
POSTGRES_PASSWORD=change-me-to-a-strong-password
